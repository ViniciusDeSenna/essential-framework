{
    "name": "essential/framework",
    "description": "Essential PHP Framework - Minimalist API-focused framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["framework", "api", "minimalist", "essential"],
    "homepage": "https://essential-framework.dev",
    "support": {
        "issues": "https://github.com/essential-framework/essential/issues",
        "docs": "https://docs.essential-framework.dev"
    },
    "authors": [
        {
            "name": "Essential Team",
            "email": "team@essential-framework.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "essential/core": "^1.0",
        "essential/cli": "^1.0",
        "essential/http": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Essential\\Framework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Essential\\Framework\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/ess"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
