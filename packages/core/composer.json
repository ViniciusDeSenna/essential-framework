{
    "name": "essential/core",
    "description": "Essential Framework - Core Components (DI Container, Config, Support)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/container": "^2.0",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Essential\\Core\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Essential\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
