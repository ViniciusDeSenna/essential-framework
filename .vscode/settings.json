        "editor.defaultFormatter": "junstyle.php-cs-fixer",
        "editor.tabSize": 4,
        "editor.wordWrap": "on"
    },
    "intelephense.environment.phpVersion": "8.2",
    "intelephense.files.maxSize": 5000000,
    "intelephense.stubs": [
        "apache",
        "bcmath",
        "bz2",
        "calendar",
        "com_dotnet",
        "Core",
        "ctype",
        "curl",
        "date",
        "dba",
