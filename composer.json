{
    "name": "essential/monorepo",
    "description": "Essential Framework - O essencial é simples. O simples é fácil. O fácil é barato.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vinícius de Senna",
            "email": "sennadevinicius@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "symfony/console": "^6.0",
        "symfony/process": "^6.0",
        "guzzlehttp/guzzle": "^7.5",
        "composer/composer": "^2.5",
        "composer/semver": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "symplify/monorepo-builder": "^11.2",
        "symplify/easy-coding-standard": "^12.0",
        "friendsofphp/php-cs-fixer": "^3.48",
        "vimeo/psalm": "^5.20",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "Essential\\Framework\\": "packages/framework/src/",
            "Essential\\Core\\": "packages/core/src/",
            "Essential\\Cli\\": "packages/cli/src/",
            "Essential\\Http\\": "packages/http/src/",
            "Essential\\Routing\\": "packages/routing/src/",
            "Essential\\Orm\\": "packages/orm/src/",
            "Essential\\HttpClient\\": "packages/httpclient/src/",
            "Essential\\Dto\\": "packages/dto/src/",
            "Essential\\Validation\\": "packages/validation/src/",
            "Essential\\Cache\\": "packages/cache/src/",
            "Essential\\Logging\\": "packages/logging/src/"
        },
        "files": [
            "packages/core/src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Essential\\Framework\\Tests\\": "packages/framework/tests/",
            "Essential\\Core\\Tests\\": "packages/core/tests/",
            "Essential\\Cli\\Tests\\": "packages/cli/tests/",
            "Essential\\Http\\Tests\\": "packages/http/tests/",
            "Essential\\Routing\\Tests\\": "packages/routing/tests/",
            "Essential\\Orm\\Tests\\": "packages/orm/tests/",
            "Essential\\HttpClient\\Tests\\": "packages/httpclient/tests/",
            "Essential\\Dto\\Tests\\": "packages/dto/tests/",
            "Essential\\Validation\\Tests\\": "packages/validation/tests/",
            "Essential\\Cache\\Tests\\": "packages/cache/tests/",
            "Essential\\Logging\\Tests\\": "packages/logging/tests/",
            "Essential\\Tests\\": "tests/"
        }
    },
    "bin": [
        "packages/cli/bin/ess"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "analyse": [
            "@phpstan",
            "@psalm"
        ],
        "phpstan": "phpstan analyse --memory-limit=2G",
        "psalm": "psalm --show-info=true",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "monorepo:merge": "monorepo-builder merge",
        "monorepo:validate": "monorepo-builder validate",
        "monorepo:propagate": "monorepo-builder propagate",
        "release": "monorepo-builder release",
        "post-install-cmd": [
            "@monorepo:validate"
        ],
        "post-update-cmd": [
            "@monorepo:validate"
        ]
    },
    "scripts-descriptions": {
        "test": "Run all tests",
        "test:unit": "Run unit tests only",
        "test:integration": "Run integration tests only",
        "test:coverage": "Generate code coverage report",
        "analyse": "Run static analysis (PHPStan + Psalm)",
        "cs:check": "Check coding standards",
        "cs:fix": "Fix coding standards violations",
        "monorepo:merge": "Merge composer.json files from packages",
        "monorepo:validate": "Validate monorepo structure",
        "monorepo:propagate": "Propagate versions to all packages",
        "release": "Create a new release"
    },
    "replace": {
        "essential/framework": "self.version",
        "essential/core": "self.version",
        "essential/cli": "self.version",
        "essential/http": "self.version",
        "essential/routing": "self.version",
        "essential/orm": "self.version",
        "essential/httpclient": "self.version",
        "essential/dto": "self.version",
        "essential/validation": "self.version",
        "essential/cache": "self.version",
        "essential/logging": "self.version"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "platform": {
            "php": "8.1"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
